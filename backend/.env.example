# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://reportify:reportify_dev_password@localhost:5432/reportify"

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-refresh-secret-too"
JWT_REFRESH_EXPIRES_IN="30d"

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# S3 / MINIO (local dev uses MinIO)
# ─────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="reportify_minio"
S3_SECRET_KEY="reportify_minio_secret"
S3_BUCKET="reportify"
S3_FORCE_PATH_STYLE="true"

# ─────────────────────────────────────────────
# AI SERVICES (NEVER expose these to the app)
# ─────────────────────────────────────────────
WHISPER_API_KEY="your-openai-api-key-for-whisper"
GEMINI_API_KEY="your-google-gemini-api-key"
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# ─────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Reportify <noreply@reportify.ca>"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
APP_URL="http://localhost:3000"
MAX_UPLOAD_SIZE_MB=100
INVITE_EXPIRY_HOURS=48
